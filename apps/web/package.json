{
  "name": "@unportfolio/web",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:bins": "for t in darwin-arm64 darwin-x64 linux-x64 linux-arm64 windows-x64; do bun build scripts/prices.ts --compile --target=bun-$t --outfile=public/bin/prices-$t || exit 1; done",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@unportfolio/core": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "decimal.js": "^10.4.3",
    "lucide-react": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "bun": "^1.3.14",
    "fast-check": "^3.23.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
