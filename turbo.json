{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "lint": { "outputs": [], "cache": false },
    "lint:fix": { "outputs": [], "cache": false },
    "format": { "outputs": [], "cache": false },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": ["*.tsbuildinfo"]
    },
    "build": {
      "dependsOn": ["^build", "lint", "typecheck"],
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "outputs": ["dist/**", "build/**"],
      "env": ["NODE_ENV", "SITE_URL"]
    },
    "preview": { "dependsOn": ["build"], "cache": false, "persistent": true },
    "dev": { "cache": false, "persistent": true },
    "test": { "outputs": ["coverage/**"], "cache": false },
    "test:watch": { "cache": false, "persistent": true }
  }
}
