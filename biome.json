{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["@unportfolio/biome-config/biome.json"],
  "vcs": { "enabled": false },
  "files": {
    "includes": [
      "!**/dist",
      "!**/node_modules",
      "!**/public",
      "!**/build",
      "!**/*.tsbuildinfo",
      "!pnpm-lock.yaml"
    ]
  },
  "overrides": [
    {
      "includes": ["packages/core/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@unportfolio/web", "@unportfolio/web/**", "**/app", "**/app/**"],
                    "message": "@unportfolio/core deve restare puro: niente import da apps/web (UI/DOM/store). Vedi ADR-0002."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["**/*.e2e.ts", "**/e2e/**/*.ts"],
      "plugins": [
        "./node_modules/@unportfolio/biome-config/no-react-internals.grit",
        "./node_modules/@unportfolio/biome-config/no-implicit-e2e-sync.grit"
      ]
    }
  ]
}
